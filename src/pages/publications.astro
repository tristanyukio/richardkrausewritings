---

<Layout title="Publications">
	<div style="max-width: 1200px; margin: 0 auto;">
		<h1 style="font-size: 2.5rem; font-weight: 300; margin-bottom: 2rem; letter-spacing: 0.05em;">
			Publications
		</h1>
		
		<nav class="publications-nav">
			<a href="#books">Books</a>
			<a href="#magazines">Magazines</a>
		</nav>
		
		<h2 id="books" class="section-heading">Books</h2>
		<div class="publications-list">
			{books.map((book) => (
				<div id={`book-${createSlug(book.title)}`} class="publication-item book-anchor">
					{book.image && (
						<div class={book.image === '/rk7.jpg' ? 'book-cover-wrapper white-cover' : 'book-cover-wrapper'}>
							<img 
								src={book.image} 
								alt={book.title}
								loading="lazy"
								class="book-cover"
							/>
						</div>
					)}
					<div class="publication-content">
						<h2 class="book-title">{book.title}</h2>
						{book.date && (
							<p class="book-date">{book.date}</p>
						)}
						<p class="book-description">{book.description}</p>
						<a href={book.amazonLink} target="_blank" rel="noopener noreferrer" class="amazon-link">
							View on Amazon →
						</a>
					</div>
				</div>
			))}
		</div>

		<h2 id="magazines" class="section-heading">Magazines</h2>
		<div class="publications-list">
			{magazines.length > 0 ? (
				magazines.map((magazine) => (
					<div class="magazine-item">
						<div class="magazine-content">
							<h3 class="magazine-title">"{magazine.title}"</h3>
							<p class="magazine-publication">
								<strong>{magazine.publication}</strong>
								{magazine.location && <span class="magazine-location"> ({magazine.location})</span>}
							</p>
							<p class="magazine-details">
								{magazine.date} • {magazine.type}
								{magazine.note && <span class="magazine-note"> • {magazine.note}</span>}
							</p>
						</div>
					</div>
				))
			) : (
				<p style="color: #666; font-style: italic;">Magazine publications coming soon.</p>
			)}
		</div>
	</div>

	<style>
		.publications-nav {
			display: flex;
			gap: 2rem;
			margin-bottom: 3rem;
			padding-bottom: 1.5rem;
			border-bottom: 1px solid #e5e5e5;
		}

		.publications-nav a {
			color: #666;
			text-decoration: none;
			font-size: 1rem;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			transition: color 0.2s;
		}

		.publications-nav a:hover {
			color: #1a1a1a;
		}

		.section-heading {
			font-size: 1.75rem;
			font-weight: 300;
			margin-top: 4rem;
			margin-bottom: 2rem;
			letter-spacing: 0.05em;
			color: #1a1a1a;
			scroll-margin-top: 2rem;
		}

		.section-heading:first-of-type {
			margin-top: 0;
		}

		.publications-list {
			display: flex;
			flex-direction: column;
			gap: 3rem;
			margin-bottom: 2rem;
		}

		.publication-item {
			display: flex;
			gap: 2.5rem;
			padding-bottom: 3rem;
			border-bottom: 1px solid #e5e5e5;
		}

		.book-anchor {
			scroll-margin-top: 2rem;
		}

		.publication-item:last-child {
			border-bottom: none;
			padding-bottom: 0;
		}

		.book-cover-wrapper {
			flex-shrink: 0;
		}

		.book-cover-wrapper.white-cover {
			background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
			padding: 0.75rem;
			border-radius: 2px;
		}

		.book-cover {
			width: 200px;
			height: 300px;
			object-fit: contain;
			box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
		}

		.publication-content {
			flex: 1;
		}

		.book-title {
			font-size: 1.5rem;
			font-weight: 400;
			margin-bottom: 0.5rem;
			color: #1a1a1a;
			line-height: 1.4;
		}

		.book-date {
			color: #666;
			font-size: 0.95rem;
			margin-bottom: 1rem;
			font-style: italic;
		}

		.book-description {
			color: #333;
			font-size: 1rem;
			line-height: 1.7;
			margin-bottom: 1.5rem;
		}

		.amazon-link {
			color: #1a1a1a;
			text-decoration: none;
			font-size: 0.95rem;
			border-bottom: 1px solid #1a1a1a;
			transition: color 0.3s ease, border-color 0.3s ease;
			display: inline-block;
		}

		.amazon-link:hover {
			color: #666;
			border-bottom-color: #666;
		}

		.magazine-item {
			padding-bottom: 2rem;
			border-bottom: 1px solid #e5e5e5;
		}

		.magazine-item:last-child {
			border-bottom: none;
			padding-bottom: 0;
		}

		.magazine-title {
			font-size: 1.25rem;
			font-weight: 400;
			margin-bottom: 0.5rem;
			color: #1a1a1a;
			font-style: italic;
		}

		.magazine-publication {
			color: #333;
			font-size: 1rem;
			margin-bottom: 0.25rem;
		}

		.magazine-location {
			color: #666;
			font-weight: normal;
		}

		.magazine-details {
			color: #666;
			font-size: 0.95rem;
			margin: 0;
		}

		.magazine-note {
			font-style: italic;
		}

		@media (max-width: 768px) {
			.publication-item {
				flex-direction: column;
				gap: 1.5rem;
			}

			.book-cover-wrapper {
				align-self: flex-start;
			}

			.book-cover {
				width: 150px;
				height: 225px;
			}

			.book-title {
				font-size: 1.25rem;
			}

			.magazine-title {
				font-size: 1.125rem;
			}
		}
	</style>
</Layout>
