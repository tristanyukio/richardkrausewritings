---
import Layout from '../components/Layout.astro';
---

<Layout title="404 - Page Not Found">
	<div style="max-width: 800px; margin: 0 auto; text-align: center; padding: 4rem 2rem;">
		<h1 style="font-size: 3rem; font-weight: 300; margin-bottom: 1rem; letter-spacing: 0.05em;">
			404
		</h1>
		<p style="font-size: 1.25rem; color: #666; margin-bottom: 2rem;">
			Page not found
		</p>
		<a href="/" style="color: #1a1a1a; text-decoration: underline; font-size: 1rem;">
			Return to Home →
		</a>
	</div>
</Layout>

